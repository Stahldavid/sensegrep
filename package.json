{
  "name": "sensegrep",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "node build.js",
    "version:check": "node scripts/check-version-consistency.mjs",
    "precheck": "npm run build",
    "check": "npm run check --workspaces --if-present",
    "changeset": "changeset",
    "version": "changeset version && node scripts/sync-versions.mjs",
    "release:verify": "node scripts/verify-release-artifacts.mjs",
    "release": "npm run build && npm run release:verify && node scripts/publish-changesets.mjs",
    "dev": "echo 'Use packages/cli or packages/mcp when implemented'",
    "pretest": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "repo:labels:apply": "node scripts/github/apply-labels.mjs",
    "demo:capture": "node scripts/media/capture-video-transcript.mjs",
    "demo:render:short": "node scripts/media/render-time-to-value.mjs short",
    "demo:render:full": "node scripts/media/render-time-to-value.mjs full",
    "demo:gif:short": "node scripts/media/make-time-to-value-gif.mjs",
    "demo:asset:short": "npm run demo:render:short && npm run demo:gif:short",
    "demo:asset:full": "npm run demo:render:full",
    "demo:render": "npm run demo:render:short",
    "demo:gif": "npm run demo:gif:short",
    "demo:asset": "npm run demo:asset:short",
    "cursor:install-link": "node scripts/mcp/generate-cursor-install-link.mjs"
  },
  "overrides": {
    "js-yaml": "^4.3.0"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.5.2",
    "@changesets/cli": "^2.31.0",
    "@types/node": "^20.19.43",
    "@types/picomatch": "^2.3.0",
    "typescript": "^5.6.3",
    "vitest": "^4.1.10"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/Stahldavid/sensegrep.git"
  },
  "homepage": "https://github.com/Stahldavid/sensegrep",
  "bugs": {
    "url": "https://github.com/Stahldavid/sensegrep/issues"
  }
}
