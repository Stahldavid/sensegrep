{
  "name": "@sensegrep/mcp",
  "mcpName": "io.github.Stahldavid/sensegrep",
  "version": "1.11.0",
  "type": "module",
  "main": "./dist/server.js",
  "bin": {
    "sensegrep-mcp": "dist/server.js"
  },
  "types": "./dist/server.d.ts",
  "files": [
    "dist",
    "!dist/**/*.test.js",
    "!dist/**/*.test.js.map",
    "!dist/**/*.test.d.ts",
    "!dist/**/*.test.d.ts.map",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\"",
    "build": "npm run clean && tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "npm run build",
    "postbuild": "node -e \"const fs = require('fs'); const p='dist/server.js'; const s='#!/usr/bin/env node\\n'; const c=fs.readFileSync(p,'utf8'); if (c.startsWith('#!')) { fs.writeFileSync(p, s + c.split(/\\r?\\n/).slice(1).join('\\n')); } else { fs.writeFileSync(p, s + c); }\""
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@sensegrep/core": "^1.11.0",
    "zod": "^4.4.3"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Stahldavid/sensegrep.git"
  },
  "homepage": "https://github.com/Stahldavid/sensegrep",
  "bugs": {
    "url": "https://github.com/Stahldavid/sensegrep/issues"
  },
  "keywords": [
    "mcp",
    "mcp-server",
    "semantic-search",
    "ai-agents",
    "code-search"
  ],
  "description": "MCP server exposing sensegrep's semantic + structural code search to AI agents, delivering smaller, more relevant context."
}
