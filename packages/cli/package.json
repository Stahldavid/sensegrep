{
  "name": "@sensegrep/cli",
  "version": "1.7.6",
  "type": "module",
  "bin": {
    "sensegrep": "dist/main.js"
  },
  "files": [
    "dist",
    "!dist/**/*.test.js",
    "!dist/**/*.test.js.map",
    "!dist/**/*.test.d.ts",
    "!dist/**/*.test.d.ts.map",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\"",
    "build": "npm run clean && tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "npm run build",
    "postbuild": "node -e \"const fs = require('fs'); const p='dist/main.js'; const s='#!/usr/bin/env node\\n'; const c=fs.readFileSync(p,'utf8'); if (c.startsWith('#!')) { fs.writeFileSync(p, s + c.split(/\\r?\\n/).slice(1).join('\\n')); } else { fs.writeFileSync(p, s + c); }\""
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@sensegrep/core": "^1.7.6"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Stahldavid/sensegrep.git"
  },
  "homepage": "https://github.com/Stahldavid/sensegrep",
  "bugs": {
    "url": "https://github.com/Stahldavid/sensegrep/issues"
  },
  "description": "Command-line semantic code search for AI coding workflows — find the right code by meaning using semantic, exact, and AST-aware retrieval.",
  "keywords": [
    "semantic-search",
    "code-search",
    "ai-agents",
    "cli",
    "grep",
    "ast"
  ]
}
