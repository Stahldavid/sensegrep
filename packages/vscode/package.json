{
  "name": "sensegrep",
  "private": true,
  "displayName": "Sensegrep",
  "description": "Semantic + structural code search with AI-powered duplicate detection",
  "version": "0.1.27",
  "publisher": "sensegrep",
  "license": "Apache-2.0",
  "icon": "resources/icon.png",
  "galleryBanner": {
    "color": "#0b1320",
    "theme": "dark"
  },
  "markdown": "github",
  "qna": "https://github.com/Stahldavid/sensegrep/discussions",
  "repository": {
    "type": "git",
    "url": "https://github.com/Stahldavid/sensegrep.git"
  },
  "homepage": "https://github.com/Stahldavid/sensegrep",
  "bugs": {
    "url": "https://github.com/Stahldavid/sensegrep/issues"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Other"
  ],
  "keywords": [
    "semantic search",
    "code search",
    "duplicate detection",
    "AI",
    "embeddings",
    "code navigation",
    "tree-sitter",
    "mcp",
    "ai agents"
  ],
  "activationEvents": [
    "onView:sensegrep.search",
    "onView:sensegrep.results",
    "onView:sensegrep.duplicates",
    "onView:sensegrep.history",
    "onCommand:sensegrep.search",
    "onCommand:sensegrep.searchAdvanced",
    "onCommand:sensegrep.survey",
    "onCommand:sensegrep.cluster",
    "onCommand:sensegrep.searchSelection",
    "onCommand:sensegrep.saveSearch",
    "onCommand:sensegrep.detectDuplicates",
    "onCommand:sensegrep.indexProject",
    "onCommand:sensegrep.reindexProject",
    "onCommand:sensegrep.showStats",
    "onCommand:sensegrep.verifyIndex",
    "onCommand:sensegrep.showStatusJson",
    "onCommand:sensegrep.toggleWatch",
    "onCommand:sensegrep.openSettings",
    "onCommand:sensegrep.foldUnrelated",
    "onCommand:sensegrep.toggleSemanticFolding",
    "onCommand:sensegrep.setIndexRoot",
    "onCommand:sensegrep.setApiKey",
    "onCommand:sensegrep.refreshResults",
    "onCommand:sensegrep.clearResults",
    "onCommand:sensegrep.goToResult",
    "onCommand:sensegrep.openResultToSide",
    "onCommand:sensegrep.copyResultLocation",
    "onCommand:sensegrep.exportSearchResults",
    "onCommand:sensegrep.exportDuplicateResults",
    "onCommand:sensegrep.editSavedSearchTags",
    "onCommand:sensegrep.removeSavedSearch"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "sensegrep.search",
        "title": "Semantic Search",
        "category": "Sensegrep",
        "icon": "$(search)"
      },
      {
        "command": "sensegrep.searchAdvanced",
        "title": "Semantic Search (Advanced)",
        "category": "Sensegrep",
        "icon": "$(filter)"
      },
      {
        "command": "sensegrep.survey",
        "title": "Survey Code Domain",
        "category": "Sensegrep",
        "icon": "$(map)"
      },
      {
        "command": "sensegrep.cluster",
        "title": "Cluster Code Theme",
        "category": "Sensegrep",
        "icon": "$(type-hierarchy)"
      },
      {
        "command": "sensegrep.searchSelection",
        "title": "Find Similar Code",
        "category": "Sensegrep",
        "icon": "$(search-fuzzy)"
      },
      {
        "command": "sensegrep.saveSearch",
        "title": "Save Search",
        "category": "Sensegrep",
        "icon": "$(star-full)"
      },
      {
        "command": "sensegrep.detectDuplicates",
        "title": "Detect Duplicates",
        "category": "Sensegrep",
        "icon": "$(copy)"
      },
      {
        "command": "sensegrep.indexProject",
        "title": "Index Project",
        "category": "Sensegrep",
        "icon": "$(database)"
      },
      {
        "command": "sensegrep.reindexProject",
        "title": "Reindex Project (Full)",
        "category": "Sensegrep",
        "icon": "$(refresh)"
      },
      {
        "command": "sensegrep.showStats",
        "title": "Show Index Stats",
        "category": "Sensegrep",
        "icon": "$(graph)"
      },
      {
        "command": "sensegrep.verifyIndex",
        "title": "Verify Index Integrity",
        "category": "Sensegrep",
        "icon": "$(check)"
      },
      {
        "command": "sensegrep.showStatusJson",
        "title": "Show Index Status (JSON)",
        "category": "Sensegrep",
        "icon": "$(json)"
      },
      {
        "command": "sensegrep.toggleWatch",
        "title": "Toggle Watch Mode",
        "category": "Sensegrep",
        "icon": "$(eye)"
      },
      {
        "command": "sensegrep.openSettings",
        "title": "Open Settings",
        "category": "Sensegrep",
        "icon": "$(gear)"
      },
      {
        "command": "sensegrep.foldUnrelated",
        "title": "Fold Unrelated Code",
        "category": "Sensegrep",
        "icon": "$(fold)"
      },
      {
        "command": "sensegrep.toggleSemanticFolding",
        "title": "Toggle Semantic Folding",
        "category": "Sensegrep",
        "icon": "$(fold)"
      },
      {
        "command": "sensegrep.setIndexRoot",
        "title": "Set Index Root",
        "category": "Sensegrep",
        "icon": "$(root-folder)"
      },
      {
        "command": "sensegrep.setApiKey",
        "title": "Set Gemini API Key",
        "category": "Sensegrep",
        "icon": "$(key)"
      },
      {
        "command": "sensegrep.refreshResults",
        "title": "Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "sensegrep.clearResults",
        "title": "Clear Results",
        "icon": "$(clear-all)"
      },
      {
        "command": "sensegrep.goToResult",
        "title": "Go to Location",
        "icon": "$(go-to-file)"
      },
      {
        "command": "sensegrep.openResultToSide",
        "title": "Open to Side",
        "icon": "$(split-horizontal)"
      },
      {
        "command": "sensegrep.copyResultLocation",
        "title": "Copy Location",
        "icon": "$(copy)"
      },
      {
        "command": "sensegrep.exportSearchResults",
        "title": "Export Search Results",
        "category": "Sensegrep",
        "icon": "$(export)"
      },
      {
        "command": "sensegrep.exportDuplicateResults",
        "title": "Export Duplicate Results",
        "category": "Sensegrep",
        "icon": "$(export)"
      },
      {
        "command": "sensegrep.editSavedSearchTags",
        "title": "Edit Search Tags",
        "icon": "$(tag)"
      },
      {
        "command": "sensegrep.removeSavedSearch",
        "title": "Remove Saved Search",
        "icon": "$(trash)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "sensegrep",
          "title": "Sensegrep",
          "icon": "resources/sensegrep.svg"
        }
      ]
    },
    "views": {
      "sensegrep": [
        {
          "id": "sensegrep.search",
          "name": "Search",
          "type": "webview"
        },
        {
          "id": "sensegrep.results",
          "name": "Results"
        },
        {
          "id": "sensegrep.duplicates",
          "name": "Duplicates",
          "type": "webview"
        },
        {
          "id": "sensegrep.history",
          "name": "Recent Searches"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "sensegrep.results",
        "contents": "No search results yet.\n[Search Code](command:sensegrep.search)"
      },
      {
        "view": "sensegrep.duplicates",
        "contents": "No duplicates detected.\n[Detect Duplicates](command:sensegrep.detectDuplicates)"
      }
    ],
    "walkthroughs": [
      {
        "id": "sensegrep.gettingStarted",
        "title": "Get Started with Sensegrep",
        "description": "Configure embeddings, index your project, and search code semantically.",
        "steps": [
          {
            "id": "configureEmbeddings",
            "title": "Configure embeddings",
            "description": "Use your shared Sensegrep config file or set provider overrides.\n\n[Open Settings](command:sensegrep.openSettings)",
            "completionEvents": [
              "onCommand:sensegrep.openSettings"
            ]
          },
          {
            "id": "indexProject",
            "title": "Index the project",
            "description": "Build the semantic index for the selected workspace root.\n\n[Index Project](command:sensegrep.indexProject)",
            "completionEvents": [
              "onCommand:sensegrep.indexProject"
            ]
          },
          {
            "id": "searchCode",
            "title": "Search semantically",
            "description": "Find code by behavior, feature, or implementation intent.\n\n[Search Code](command:sensegrep.search)",
            "completionEvents": [
              "onCommand:sensegrep.search"
            ]
          }
        ]
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "sensegrep.refreshResults",
          "when": "view == sensegrep.results",
          "group": "navigation"
        },
        {
          "command": "sensegrep.clearResults",
          "when": "view == sensegrep.results",
          "group": "navigation"
        },
        {
          "command": "sensegrep.detectDuplicates",
          "when": "view == sensegrep.duplicates",
          "group": "navigation"
        },
        {
          "command": "sensegrep.exportSearchResults",
          "when": "view == sensegrep.results",
          "group": "navigation"
        },
        {
          "command": "sensegrep.exportDuplicateResults",
          "when": "view == sensegrep.duplicates",
          "group": "navigation"
        },
        {
          "command": "sensegrep.saveSearch",
          "when": "view == sensegrep.history",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "sensegrep.openResultToSide",
          "when": "view == sensegrep.results && viewItem == searchResultItem",
          "group": "inline"
        },
        {
          "command": "sensegrep.copyResultLocation",
          "when": "view == sensegrep.results && viewItem == searchResultItem",
          "group": "inline"
        },
        {
          "command": "sensegrep.saveSearch",
          "when": "view == sensegrep.history && viewItem == recentSearchItem",
          "group": "inline"
        },
        {
          "command": "sensegrep.editSavedSearchTags",
          "when": "view == sensegrep.history && viewItem == savedSearchItem",
          "group": "inline"
        },
        {
          "command": "sensegrep.removeSavedSearch",
          "when": "view == sensegrep.history && viewItem == savedSearchItem",
          "group": "inline"
        }
      ],
      "editor/context": [
        {
          "command": "sensegrep.searchSelection",
          "when": "editorHasSelection",
          "group": "sensegrep@1"
        }
      ],
      "commandPalette": [
        {
          "command": "sensegrep.search",
          "when": "workspaceFolderCount > 0"
        },
        {
          "command": "sensegrep.searchAdvanced",
          "when": "workspaceFolderCount > 0"
        },
        {
          "command": "sensegrep.survey",
          "when": "workspaceFolderCount > 0"
        },
        {
          "command": "sensegrep.cluster",
          "when": "workspaceFolderCount > 0"
        },
        {
          "command": "sensegrep.detectDuplicates",
          "when": "workspaceFolderCount > 0"
        },
        {
          "command": "sensegrep.indexProject",
          "when": "workspaceFolderCount > 0"
        },
        {
          "command": "sensegrep.verifyIndex",
          "when": "workspaceFolderCount > 0"
        },
        {
          "command": "sensegrep.showStatusJson",
          "when": "workspaceFolderCount > 0"
        },
        {
          "command": "sensegrep.saveSearch",
          "when": "workspaceFolderCount > 0"
        },
        {
          "command": "sensegrep.foldUnrelated",
          "when": "editorTextFocus"
        },
        {
          "command": "sensegrep.toggleSemanticFolding",
          "when": "workspaceFolderCount > 0"
        },
        {
          "command": "sensegrep.setIndexRoot",
          "when": "workspaceFolderCount > 0"
        },
        {
          "command": "sensegrep.exportSearchResults",
          "when": "workspaceFolderCount > 0"
        },
        {
          "command": "sensegrep.exportDuplicateResults",
          "when": "workspaceFolderCount > 0"
        }
      ]
    },
    "configuration": {
      "title": "Sensegrep",
      "properties": {
        "sensegrep.autoIndex": {
          "type": "boolean",
          "default": false,
          "scope": "resource",
          "description": "Automatically index the project when Sensegrep activates"
        },
        "sensegrep.watchMode": {
          "type": "boolean",
          "default": true,
          "scope": "resource",
          "description": "Watch for file changes and reindex automatically"
        },
        "sensegrep.watchIntervalMs": {
          "type": "number",
          "default": 60000,
          "scope": "resource",
          "description": "Minimum interval between auto-reindexing (ms)"
        },
        "sensegrep.includeDocs": {
          "type": "boolean",
          "default": false,
          "scope": "resource",
          "description": "Include Markdown and documentation files in the semantic index"
        },
        "sensegrep.includeConfig": {
          "type": "boolean",
          "default": false,
          "scope": "resource",
          "description": "Include JSON, YAML, and TOML config files in the semantic index"
        },
        "sensegrep.showCodeLens": {
          "type": "boolean",
          "default": true,
          "description": "Show Find Similar CodeLens on functions and methods"
        },
        "sensegrep.showDiagnostics": {
          "type": "boolean",
          "default": true,
          "description": "Show duplicate warnings in Problems panel"
        },
        "sensegrep.semanticFolding": {
          "type": "boolean",
          "default": true,
          "description": "Collapse unrelated code when navigating to results"
        },
        "sensegrep.duplicateThreshold": {
          "type": "number",
          "default": 0.85,
          "minimum": 0.5,
          "maximum": 1,
          "scope": "resource",
          "description": "Minimum similarity threshold for duplicate detection (0.5-1.0)"
        },
        "sensegrep.defaultSymbolTypes": {
          "type": "array",
          "default": [
            "function",
            "method"
          ],
          "scope": "resource",
          "items": {
            "type": "string"
          },
          "description": "Default symbol types to search (e.g., function, method, class, interface, type, variable, namespace, enum)"
        },
        "sensegrep.excludePatterns": {
          "type": "array",
          "default": [
            "*.test.ts",
            "*.spec.ts",
            "**/__tests__/**"
          ],
          "scope": "resource",
          "items": {
            "type": "string"
          },
          "description": "File patterns to exclude from indexing"
        },
        "sensegrep.maxResultsPerFile": {
          "type": "number",
          "default": 3,
          "scope": "resource",
          "description": "Maximum results per file"
        },
        "sensegrep.indexRoot": {
          "type": "string",
          "default": "",
          "scope": "resource",
          "description": "Override root folder used for indexing/search (share index with CLI/MCP)"
        },
        "sensegrep.logLevel": {
          "type": "string",
          "enum": [
            "DEBUG",
            "INFO",
            "WARN",
            "ERROR"
          ],
          "default": "WARN",
          "description": "Sensegrep log verbosity"
        },
        "sensegrep.embeddings.provider": {
          "type": "string",
          "enum": [
            "config",
            "gemini",
            "openai",
            "bedrock"
          ],
          "enumDescriptions": [
            "Read ~/.config/sensegrep/config.json and environment variables.",
            "Use Gemini embeddings with the Gemini API key stored in VS Code secrets or environment.",
            "Use an OpenAI-compatible embeddings API such as LM Studio.",
            "Use Amazon Bedrock embeddings through config or environment credentials."
          ],
          "default": "config",
          "description": "Remote embeddings provider. Use config to read ~/.config/sensegrep/config.json and environment variables"
        },
        "sensegrep.embeddings.model": {
          "type": "string",
          "default": "",
          "description": "Embedding model name. Leave empty to use ~/.config/sensegrep/config.json"
        },
        "sensegrep.embeddings.dimension": {
          "type": "number",
          "default": 0,
          "description": "Embedding dimension. Leave 0 to use ~/.config/sensegrep/config.json"
        },
        "sensegrep.embeddings.baseUrl": {
          "type": "string",
          "default": "",
          "description": "OpenAI-compatible API base URL (e.g. http://127.0.0.1:1234/v1 for LM Studio). Leave empty to use ~/.config/sensegrep/config.json"
        },
        "sensegrep.embeddings.region": {
          "type": "string",
          "default": "",
          "description": "Amazon Bedrock region. Leave empty to use ~/.config/sensegrep/config.json or environment variables"
        },
        "sensegrep.embeddings.apiKey": {
          "type": "string",
          "default": "",
          "description": "API key for the selected embeddings provider. Leave empty to use ~/.config/sensegrep/config.json or environment variables"
        },
        "sensegrep.geminiApiKey": {
          "type": "string",
          "default": "",
          "description": "Gemini API key (optional, can use GEMINI_API_KEY env var)"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "node build.js",
    "dev": "node build.js --watch",
    "package": "vsce package --no-dependencies --skip-license",
    "package:win32-x64": "vsce package --target win32-x64 --no-dependencies --skip-license",
    "package:linux-x64": "vsce package --target linux-x64 --no-dependencies --skip-license",
    "package:darwin-x64": "vsce package --target darwin-x64 --no-dependencies --skip-license",
    "package:darwin-arm64": "vsce package --target darwin-arm64 --no-dependencies --skip-license",
    "publish": "vsce publish --no-dependencies --skip-license",
    "check": "npm run lint",
    "lint": "tsc --noEmit",
    "test": "node test/run-tests.cjs"
  },
  "devDependencies": {
    "@types/node": "^20.19.27",
    "@types/vscode": "^1.85.0",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^2.32.0",
    "esbuild": "^0.27.2",
    "picomatch": "^4.0.4",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@sensegrep/core": "^1.6.11"
  }
}
